# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/chopsave

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256 keys — PEM encoded, use \n for newlines in a single-line value)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ─── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_WEBHOOK_SECRET=

# ─── Flutterwave ──────────────────────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# ─── Termii SMS ───────────────────────────────────────────────────────────────
TERMII_API_KEY=

# ─── Firebase Cloud Messaging ─────────────────────────────────────────────────
# JSON service account key (stringify the JSON and place it here)
FCM_SERVICE_ACCOUNT=

# ─── AWS S3 / Cloudflare R2 ───────────────────────────────────────────────────
AWS_S3_BUCKET=chopsave-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
